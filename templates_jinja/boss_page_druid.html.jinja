<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Healer Audit — {{ healer_name }} — {{ boss_name }}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

  :root{
    --ink: #132A2C;
    --ink-2: #1C3A3D;
    --parchment: #F3E9D6;
    --parchment-dim: #E8DBC2;
    --copper: #C97A3D;
    --moss: #5F7A52;
    --rust: #B5503A;
    --gold: #D9B25C;
    --line: rgba(19,42,44,0.16);
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    background-color: var(--ink);
    background-image:
      radial-gradient(circle at 15% 0%, rgba(217,178,92,0.06), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(201,122,61,0.05), transparent 45%),
      url('../../assets/bg-default-2.png');
    background-repeat: no-repeat, no-repeat, no-repeat;
    background-position: 15% 0%, 90% 80%, center center;
    background-size: auto, auto, cover;
    background-attachment: scroll, scroll, fixed;
    color: var(--parchment);
    font-family:'Inter', sans-serif;
    padding: 48px 24px 80px;
  }

  .page{
    max-width: 880px;
    margin: 0 auto;
    background: var(--parchment);
    color: var(--ink);
    border-radius: 4px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.45);
    overflow: hidden;
  }

  .header{
    padding: 40px 48px 32px;
    border-bottom: 1px solid var(--line);
    display:flex;
    flex-direction: column;
    gap: 18px;
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin: 0 0 10px;
  }
  h1{
    font-family:'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 40px;
    line-height: 1.05;
    margin: 0 0 8px;
  }
  .subline{
    font-size: 14px;
    color: rgba(19,42,44,0.65);
    margin: 0;
  }
  .subline span{ font-family:'IBM Plex Mono', monospace; }

  .seal-wrap{ flex-shrink:0; width: 108px; text-align:center; }
  .seal{ width: 108px; height: 108px; }
  .seal-label{
    font-family:'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 6px;
    color: rgba(19,42,44,0.55);
  }

  .section{ padding: 32px 48px; border-bottom: 1px solid var(--line); }
  .section:last-child{ border-bottom: none; }
  .section-head{
    display:flex; align-items:baseline; gap: 12px; margin-bottom: 20px;
  }
  .section-num{
    font-family:'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--copper);
  }
  .section-title{
    font-family:'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 24px;
    margin: 0;
  }
  .section-desc{
    font-size: 13px;
    color: rgba(19,42,44,0.6);
    margin: -12px 0 20px;
  }

  .stat-grid{
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 3px;
    overflow:hidden;
  }
  .stat-grid.stat-grid-5{ grid-template-columns: repeat(5, 1fr); }
  .stat{
    padding: 16px 18px;
    border-right: 1px solid var(--line);
  }
  .stat:last-child{ border-right:none; }
  .stat-label{
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(19,42,44,0.55);
    margin-bottom: 6px;
  }
  .stat-value{
    font-family:'IBM Plex Mono', monospace;
    font-size: 22px;
    font-weight: 600;
  }
  .stat-value.good{ color: var(--moss); }
  .stat-value.warn{ color: var(--rust); }
  .stat-sub{ font-size: 11px; color: rgba(19,42,44,0.5); margin-top:2px; }

  .pctl-track{
    position: relative;
    height: 10px;
    background: linear-gradient(to right, var(--rust), var(--gold) 60%, var(--moss));
    border-radius: 5px;
    margin: 18px 0 6px;
  }
  .pctl-marker{
    position: absolute;
    top: -8px;
    width: 3px;
    height: 26px;
    background: var(--ink);
  }
  .pctl-marker::after{
    content: attr(data-label);
    position: absolute;
    top: -22px;
    left: 50%;
    transform: translateX(-50%);
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    white-space: nowrap;
    color: var(--ink);
  }
  .pctl-scale{
    display:flex; justify-content: space-between;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10px;
    color: rgba(19,42,44,0.45);
  }

  .spell-row{
    display:grid;
    grid-template-columns: 140px 1fr 60px;
    align-items:center;
    gap: 14px;
    padding: 9px 0;
    font-size: 13px;
  }
  .spell-name{ font-weight: 500; }
  .spell-bar-track{
    height: 8px;
    background: var(--parchment-dim);
    border-radius: 4px;
    overflow:hidden;
  }
  .spell-bar-fill{ height:100%; border-radius:4px; background: var(--copper); }
  .spell-pct{ font-family:'IBM Plex Mono', monospace; text-align:right; }
  .compare-row .spell-bar-fill.dim{ background: rgba(19,42,44,0.25); }
  .compare-legend{
    display:flex; gap: 18px; margin-bottom: 14px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
  }
  .dot{ display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:6px; }

  .check-list{ display:flex; flex-direction:column; }
  .check-item{
    display:grid;
    grid-template-columns: 22px 1fr auto;
    align-items:center;
    gap: 12px;
    padding: 10px 0;
    border-top: 1px dashed var(--line);
    font-size: 13px;
  }
  .check-item:first-child{ border-top:none; }
  .check-icon{
    width: 18px; height: 18px;
    border-radius: 50%;
    display:flex; align-items:center; justify-content:center;
    font-size: 11px;
    font-weight: 700;
  }
  .check-icon.ok{ background: var(--moss); color: var(--parchment); }
  .check-icon.bad{ background: var(--rust); color: var(--parchment); }
  .check-note{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(19,42,44,0.55);
    text-align:right;
  }

  .cd-table{ width:100%; border-collapse: collapse; font-size: 13px; }
  .cd-table th{
    text-align:left;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(19,42,44,0.5);
    padding: 8px 10px;
    border-bottom: 1px solid var(--line);
  }
  .cd-table td{
    padding: 10px 10px;
    border-bottom: 1px dashed var(--line);
    vertical-align: middle;
  }
  .cd-table tr:last-child td{ border-bottom:none; }
  .cd-table .num-cell{ font-family:'IBM Plex Mono', monospace; text-align:right; }
  .cd-table .ability-name{ font-weight: 500; }

  .target-list{ display:flex; flex-direction:column; gap:8px; }
  .target-row{
    display:grid;
    grid-template-columns: 120px 1fr 70px;
    align-items:center;
    gap: 12px;
    font-size: 13px;
  }
  .target-bar-track{ height:14px; background:var(--parchment-dim); border-radius:3px; overflow:hidden; }
  .target-bar-fill{ height:100%; background: var(--ink-2); }
  .target-pct{ font-family:'IBM Plex Mono', monospace; text-align:right; }

  .healer-bar-track{ height:14px; background:var(--parchment-dim); border-radius:3px; overflow:hidden; min-width:80px; }
  .healer-bar-fill{ height:100%; background: var(--ink-2); }
  .healer-bar-fill.is-character{ background: var(--copper); }
  tr.is-character td{ font-weight:700; }

  .coverage-note{
    margin-top: 14px;
    font-size: 12px;
    color: rgba(19,42,44,0.6);
    border-left: 3px solid var(--gold);
    padding-left: 12px;
  }

  .footer{
    padding: 24px 48px 32px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(19,42,44,0.4);
    display:flex;
    justify-content: space-between;
  }

  .placeholder-tag{
    display:inline-block;
    margin-left: 10px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--copper);
    border: 1px solid var(--copper);
    border-radius: 20px;
    padding: 2px 8px;
    vertical-align: middle;
  }

  .tabs{
    display:flex;
    gap: 4px;
    padding: 0 48px;
    background: var(--parchment-dim);
    border-bottom: 1px solid var(--line);
  }
  .tab-btn{
    appearance:none;
    border:none;
    background:none;
    cursor:pointer;
    font-family:'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(19,42,44,0.5);
    padding: 14px 18px 12px;
    border-bottom: 2px solid transparent;
  }
  .tab-btn.active{ color: var(--ink); border-bottom-color: var(--copper); }
  .tab-panel{ display:none; }
  .tab-panel.active{ display:block; }
</style>
{% if theme_style_block %}{{ theme_style_block|safe }}{% endif %}
</head>
<body>

<div class="page">

  <div class="header">
    <div>
      <p class="eyebrow"><a href="index.html" style="color:var(--copper); text-decoration:none;">← Raid overview</a> &nbsp;·&nbsp; Healer Audit — {{ raid_title }} · {{ boss_name }}</p>
      <h1>{{ healer_name }}</h1>
      <p class="subline">{{ healer_class_spec }} &nbsp;·&nbsp; ilvl {{ item_level }} &nbsp;·&nbsp; report <span>{{ report_code }}</span> &nbsp;·&nbsp; fight <span>{{ fight_id }}</span> &nbsp;·&nbsp; kill, {{ duration_s }}s{% if theme_tag %} &nbsp;·&nbsp; <span style="color:var(--copper);">{{ theme_tag }}</span>{% endif %}</p>
    </div>
    <div style="display:flex; flex-wrap:wrap; justify-content:flex-start; gap:12px 16px; align-items:flex-start;">
      <div class="seal-wrap">
        <svg class="seal" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="56" fill="none" stroke="{{ percentile_color }}" stroke-width="2"/>
          <circle cx="60" cy="60" r="48" fill="none" stroke="{{ percentile_color }}" stroke-width="1" stroke-dasharray="2 4"/>
          <text x="60" y="66" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="700" font-size="26" fill="{{ percentile_color }}">{{ percentile }}</text>
          <text x="60" y="82" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="9" letter-spacing="0.05em" fill="#132A2C" opacity="0.6">PERCENTILE</text>
        </svg>
        <div class="seal-label">WCL rank, all parses</div>
      </div>
      {% if ilvl_seal %}
      <div class="seal-wrap" style="cursor:help;" title="{{ ilvl_seal.tooltip }}">
        <svg class="seal" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="56" fill="none" stroke="{{ ilvl_seal.color }}" stroke-width="2"/>
          <circle cx="60" cy="60" r="48" fill="none" stroke="{{ ilvl_seal.color }}" stroke-width="1" stroke-dasharray="2 4"/>
          <text x="60" y="60" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="700" font-size="22" fill="{{ ilvl_seal.color }}">{{ ilvl_seal.ordinal }} of {{ ilvl_seal.count }}</text>
          <text x="60" y="78" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="8" letter-spacing="0.05em" fill="#132A2C" opacity="0.6">ILVL HEALING RANK</text>
        </svg>
        <div class="seal-label">{{ ilvl_seal.label }}</div>
      </div>
      {% endif %}
      {% if raw_seal %}
      <div class="seal-wrap" style="cursor:help;" title="{{ raw_seal.tooltip }}">
        <svg class="seal" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="56" fill="none" stroke="{{ raw_seal.color }}" stroke-width="2"/>
          <circle cx="60" cy="60" r="48" fill="none" stroke="{{ raw_seal.color }}" stroke-width="1" stroke-dasharray="2 4"/>
          <text x="60" y="60" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="700" font-size="22" fill="{{ raw_seal.color }}">{{ raw_seal.ordinal }} of {{ raw_seal.count }}</text>
          <text x="60" y="78" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="8" letter-spacing="0.05em" fill="#132A2C" opacity="0.6">RAW HEALING RANK</text>
        </svg>
        <div class="seal-label">{{ raw_seal.label }}</div>
      </div>
      {% endif %}
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn active" type="button" data-tab="report">Report</button>
    <button class="tab-btn" type="button" data-tab="coaching">Coaching</button>
  </div>

  <div id="tab-report" class="tab-panel active">

  <div class="section">
    <div class="section-head">
      <span class="section-num">01</span>
      <h2 class="section-title">Scorecard</h2>
    </div>
    <div class="stat-grid stat-grid-5">
      <div class="stat">
        <div class="stat-label">HPS</div>
        <div class="stat-value">{{ hps }}</div>
        <div class="stat-sub">Top 100: #1 {{ hps_top1 }} &nbsp;·&nbsp; avg {{ hps_top100avg }} &nbsp;·&nbsp; median {{ hps_median }}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Overheal</div>
        <div class="stat-value">{{ overheal_pct }}%</div>
        <div class="stat-sub">Top 100: best {{ overheal_best }}% &nbsp;·&nbsp; median {{ overheal_median }}% &nbsp;·&nbsp; worst {{ overheal_worst }}%</div>
      </div>
      <div class="stat">
        <div class="stat-label">Effective healing</div>
        <div class="stat-value">{{ total_healing }}</div>
        <div class="stat-sub">over {{ duration_s }}s kill</div>
      </div>
      <div class="stat">
        <div class="stat-label">Active time</div>
        <div class="stat-value">{{ active_time_pct }}%</div>
        <div class="stat-sub">Top 100: #1 {{ active_time_top1 }}% &nbsp;·&nbsp; avg {{ active_time_top100avg }}% &nbsp;·&nbsp; median {{ active_time_median }}%</div>
      </div>
      <div class="stat">
        <div class="stat-label">Raid deaths</div>
        <div class="stat-value">{{ death_count }}</div>
        <div class="stat-sub">this kill, all classes</div>
      </div>
    </div>

    <div class="pctl-track">
      <div class="pctl-marker" style="left:{{ percentile }}%;" data-label="{{ healer_name }} · {{ percentile }}th"></div>
    </div>
    <div class="pctl-scale"><span>0th</span><span>50th</span><span>100th</span></div>
    <div class="stat-sub" style="margin-top:6px;">WCL rank {{ rank }} of {{ out_of }} {{ healer_class_spec }} parses on this encounter (all difficulties/partitions, historical). If matched via a duplicate raid upload rather than an exact report/fight ID, say so explicitly here.</div>

    <div class="coverage-note">{{ scorecard_finding }}</div>
  </div>

  <div class="section">
    <div class="section-head">
      <span class="section-num">02</span>
      <h2 class="section-title">Spell composition</h2>
    </div>
    <p class="section-desc">{{ healer_name }}'s real cast mix on this kill, vs. real Top 100 average on {{ boss_name }}.</p>

    <div class="compare-legend">
      <span><span class="dot" style="background:#C97A3D"></span>{{ healer_name }}</span>
      <span><span class="dot" style="background:rgba(19,42,44,0.25)"></span>Top 100 avg</span>
    </div>

    {% for row in spell_rows %}
    <div class="spell-row compare-row">
      <div class="spell-name">{{ row.name }}</div>
      <div class="spell-bar-track"><div class="spell-bar-fill" style="width:{{ row.character_pct }}%"></div></div>
      <div class="spell-pct">{{ row.character_pct }}%</div>
    </div>
    <div class="spell-row compare-row">
      <div class="spell-name"></div>
      <div class="spell-bar-track"><div class="spell-bar-fill dim" style="width:{{ row.benchmark_pct }}%"></div></div>
      <div class="spell-pct">{{ row.benchmark_pct }}%</div>
    </div>
    {% endfor %}

    <div class="coverage-note">{{ spell_composition_finding }}</div>

    {% if rank_rows %}
    <div style="margin-top:20px;">
      <p class="section-desc" style="margin:0 0 10px;">Spells with more than one real rank in play this kill (different real guids sharing a display name, not the same spell cast at different frequencies) — mana cost is this kill's own real cast data where available; <span style="font-family:'IBM Plex Mono', monospace;">&#8224;</span> marks a rank the character didn't cast this kill, backfilled with a real cost observed elsewhere in the Top 100 sample; "?" only when neither source has it.</p>
      <table class="cd-table">
        <thead>
          <tr>
            <th>Spell</th>
            <th style="text-align:right;">Mana cost</th>
            <th style="text-align:right;">{{ healer_name }}</th>
            <th style="text-align:right;">Top 100 avg</th>
          </tr>
        </thead>
        <tbody>
          {% for row in rank_rows %}
          <tr>
            <td class="ability-name">{{ row.name }}</td>
            <td class="num-cell">{{ row.mana_cost }}</td>
            <td class="num-cell">{{ row.character_pct }}%</td>
            <td class="num-cell">{{ row.benchmark_pct }}%</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </div>

  <div class="section">
    <div class="section-head">
      <span class="section-num">03</span>
      <h2 class="section-title">Cooldowns &amp; consumables</h2>
    </div>
    <p class="section-desc">Real cooldown/utility usage, consumable casts, mana efficiency, and self-buff status on this kill, vs. real Top 100 average on {{ boss_name }}. Sourced from the fight's <span class="placeholder-tag">*_casts_events.json</span> and <span class="placeholder-tag">*_consumables.json</span> - match abilities by guid, not localized name.</p>

    <table class="cd-table">
      <thead>
        <tr>
          <th>Cooldown / utility</th>
          <th style="text-align:right;">{{ healer_name }}</th>
          <th>Target</th>
          <th style="text-align:right;">Top 100 avg (self%)</th>
        </tr>
      </thead>
      <tbody>
        {% for row in cd_rows %}
        <tr>
          <td class="ability-name">{{ row.name }}</td>
          <td class="num-cell">{{ row.casts }}</td>
          <td>{{ row.target }}</td>
          <td class="num-cell">{{ row.benchmark }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    <div class="stat-grid stat-grid-5" style="margin-top:22px;">
      <div class="stat">
        <div class="stat-label">Flask / Elixir</div>
        <div class="stat-value">{{ flask_active }}</div>
        <div class="stat-sub">{{ flask_name }} — Top 100 active at pull start: {{ flask_benchmark_pct }}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Food buff</div>
        <div class="stat-value">{{ food_active }}</div>
        <div class="stat-sub">{{ food_name }} — Top 100: {{ food_benchmark_pct }}% had one active at pull start</div>
      </div>
      <div class="stat">
        <div class="stat-label">Tree of Life uptime</div>
        <div class="stat-value">{{ tree_of_life_pct }}%</div>
        <div class="stat-sub">Top 100 avg: {{ tree_of_life_benchmark_pct }}%</div>
      </div>
      <div class="stat">
        <div class="stat-label">Mana consumables</div>
        <div class="stat-value">{{ mana_consumable_count }}</div>
        <div class="stat-sub">{{ mana_consumable_detail }}</div>
      </div>
      <div class="stat">
        <div class="stat-label">HPM</div>
        <div class="stat-value">{{ hpm }}</div>
        <div class="stat-sub">Top 100: top1 {{ hpm_top1 }} &nbsp;·&nbsp; avg {{ hpm_top100avg }} &nbsp;·&nbsp; median {{ hpm_median }}</div>
      </div>
    </div>

    <div class="coverage-note">{{ cooldown_finding }}</div>
  </div>

  <div class="section">
    <div class="section-head">
      <span class="section-num">04</span>
      <h2 class="section-title">Target distribution</h2>
    </div>
    <p class="section-desc">Top 5 recipients of {{ healer_name }}'s healing on this kill ({{ coverage_pct }}% coverage) vs. Top 100 average on {{ boss_name }} ({{ benchmark_coverage_pct }}% coverage, {{ benchmark_top1_pct }}% to top target).</p>

    <div class="target-list">
      {% for row in target_rows %}
      <div class="target-row">
        <div>{{ row.name }}</div>
        <div class="target-bar-track"><div class="target-bar-fill" style="width:{{ row.bar_width }}%"></div></div>
        <div class="target-pct">{{ row.pct }}%</div>
      </div>
      {% endfor %}
    </div>

    <div class="coverage-note">{{ target_finding }}</div>
  </div>

  {% if healer_rank_rows %}
  <div class="section">
    <div class="section-head">
      <span class="section-num">05</span>
      <h2 class="section-title">Healer ranking</h2>
    </div>
    <p class="section-desc">{{ healer_name }} vs. the other healers in this same raid on this same fight.</p>
    <table class="cd-table">
      <thead>
        <tr>
          <th>Healer</th>
          <th>Raw healing</th>
          <th style="text-align:right;">% of total</th>
          <th style="text-align:right; cursor:help;" title="WCL's own Item Level percentile: how this healer's HPS on this kill compares to other same-spec, similar-item-level healers across WCL's whole parse database. Higher = stronger performance for that gear level, not just more gear.">Item Level %</th>
        </tr>
      </thead>
      <tbody>
        {% for row in healer_rank_rows %}
        <tr class="{{ row.char_class }}">
          <td class="ability-name">{{ row.name }}</td>
          <td><div class="healer-bar-track" style="cursor:help;" title="{{ row.total_tooltip }}"><div class="healer-bar-fill {{ row.char_class }}" style="width:{{ row.bar_width }}%"></div></div></td>
          <td class="num-cell">{{ row.total_pct }}</td>
          <td class="num-cell" style="cursor:help;" title="WCL's own Item Level percentile: how this healer's HPS on this kill compares to other same-spec, similar-item-level healers across WCL's whole parse database. Higher = stronger performance for that gear level, not just more gear.">{{ row.ilvl_pct }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  </div>

  <div id="tab-coaching" class="tab-panel">
    <div class="section">
      <div class="section-head">
        <span class="section-num">01</span>
        <h2 class="section-title">Mana-timing efficiency</h2>
      </div>
      {% if mana_timing %}
      <p class="section-desc">How {{ healer_name }}'s mana pool moved across this kill, derived from real per-cast mana readings ({{ mana_timing.ReadingCount }} sampled casts) — a step-function approximation between cast moments, not a continuous trace.</p>
      <div class="stat-grid stat-grid-5">
        <div class="stat">
          <div class="stat-label">Starting mana</div>
          <div class="stat-value">{{ mana_timing.StartingManaPct }}%</div>
        </div>
        <div class="stat">
          <div class="stat-label">Ending mana (approx)</div>
          <div class="stat-value">{{ mana_timing.EndingManaPctApprox }}%</div>
        </div>
        <div class="stat">
          <div class="stat-label">Casts below {{ mana_timing.LowThreshold }}%</div>
          <div class="stat-value">{{ mana_timing.LowManaCastCount }}</div>
        </div>
        <div class="stat">
          <div class="stat-label">Time below {{ mana_timing.LowThreshold }}%</div>
          <div class="stat-value">{{ mana_timing.TimeBelowLowThresholdPct }}%</div>
        </div>
        <div class="stat">
          <div class="stat-label">Time above {{ mana_timing.HighThreshold }}%</div>
          <div class="stat-value">{{ mana_timing.TimeAboveHighThresholdPct }}%</div>
        </div>
      </div>
      {% if missed_second_potion_window %}
      <div class="coverage-note">A second Mana Potion use (120s internal cooldown) would have been available before this kill ended, based on the timing of the first use, but wasn't cast again.</div>
      {% endif %}
      {% else %}
      <p class="section-desc">No usable mana-cast readings for this kill (either a build with no real mana pool, or the raw cast data predates this feature — re-run <span class="placeholder-tag">build-coaching</span>).</p>
      {% endif %}
      <div class="coverage-note">{{ mana_timing_finding }}</div>
    </div>
  </div>

  <div class="footer">
    <span>All data real: {{ healer_name }}'s fight log ({{ report_code }}, fight {{ fight_id }}) + Top 100 {{ boss_name }} benchmark (n={{ benchmark_n }})</span>
  </div>

</div>

<script>
  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
      document.querySelectorAll('.tab-panel').forEach(function (p) { p.classList.remove('active'); });
      btn.classList.add('active');
      document.getElementById('tab-' + btn.getAttribute('data-tab')).classList.add('active');
    });
  });
</script>

</body>
</html>
