<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>All Thunder No Fury — Healer Analysis</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

  :root{
    --ink: #132A2C;
    --parchment: #F3E9D6;
    --parchment-dim: #E8DBC2;
    --copper: #C97A3D;
    --moss: #5F7A52;
    --gold: #D9B25C;
    --line: rgba(19,42,44,0.16);
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    background-color: var(--ink);
    background-image:
      radial-gradient(circle at 15% 0%, rgba(217,178,92,0.06), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(201,122,61,0.05), transparent 45%),
      url('assets/bg-default-2.png');
    background-repeat: no-repeat, no-repeat, no-repeat;
    background-position: 15% 0%, 90% 80%, center center;
    background-size: auto, auto, cover;
    background-attachment: scroll, scroll, fixed;
    color: var(--parchment);
    font-family:'Inter', sans-serif;
    padding: 48px 24px 80px;
    min-height: 100vh;
  }

  .page{
    max-width: 720px;
    margin: 0 auto;
    background: var(--parchment);
    color: var(--ink);
    border-radius: 4px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.45);
    overflow: hidden;
  }

  .header{ padding: 40px 48px 32px; border-bottom: 1px solid var(--line); }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin: 0 0 10px;
  }
  h1{
    font-family:'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 40px;
    line-height: 1.08;
    margin: 0 0 8px;
  }
  .subline{ font-size: 14px; color: rgba(19,42,44,0.65); margin: 0; }

  .section{ padding: 32px 48px; }
  .section-desc{ font-size: 13px; color: rgba(19,42,44,0.6); margin: 0 0 20px; }

  .healer-list{ display:flex; flex-direction:column; }
  .healer-row{
    display:grid;
    grid-template-columns: 1fr auto auto;
    align-items:center;
    gap: 18px;
    padding: 18px 4px;
    border-top: 1px dashed var(--line);
    text-decoration: none;
    color: var(--ink);
    transition: padding-left 0.15s ease;
  }
  .healer-row:first-child{ border-top:none; }
  .healer-row:hover{ padding-left: 10px; }
  .healer-row:hover .healer-name{ color: var(--copper); }
  .healer-name{
    font-family:'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 20px;
    transition: color 0.15s ease;
  }
  .healer-class{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(19,42,44,0.5);
  }
  .healer-arrow{
    font-family:'IBM Plex Mono', monospace;
    color: var(--copper);
    opacity: 0.6;
  }
  .healer-row:hover .healer-arrow{ opacity: 1; }

  .footer{
    padding: 24px 48px 32px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(19,42,44,0.4);
  }
</style>
</head>
<body>

<div class="page">

  <div class="header">
    <p class="eyebrow">Guild Healer Analysis</p>
    <h1>All Thunder No Fury</h1>
    <p class="subline">Select a healer to view their raid history and per-boss audits.</p>
  </div>

  <div class="section">
    <p class="section-desc">Each healer's page lists every raid night analyzed, broken down boss by boss.</p>
    <div class="healer-list">
      {% for healer in healers %}
      <a class="healer-row" href="{{ healer.healer_slug }}/index.html">
        <div>
          <div class="healer-name">{{ healer.character_name }}</div>
        </div>
        <div class="healer-class">{{ healer.display_name }}</div>
        <div class="healer-arrow">→</div>
      </a>
      {% endfor %}
    </div>
  </div>

  <div class="footer">
    <span>All Thunder No Fury · Healer Analysis</span>
  </div>

</div>

</body>
</html>
