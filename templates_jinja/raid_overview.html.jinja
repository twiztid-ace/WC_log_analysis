<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Raid Audit — {{ healer_name }} — {{ raid_title }} — {{ raid_date_display }}</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap');

  :root{
    --ink: #132A2C;
    --ink-2: #1C3A3D;
    --parchment: #F3E9D6;
    --parchment-dim: #E8DBC2;
    --copper: #C97A3D;
    --moss: #5F7A52;
    --rust: #B5503A;
    --gold: #D9B25C;
    --line: rgba(19,42,44,0.16);
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    background-color: var(--ink);
    background-image:
      radial-gradient(circle at 15% 0%, rgba(217,178,92,0.06), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(201,122,61,0.05), transparent 45%),
      url('../../assets/bg-default-2.png');
    background-repeat: no-repeat, no-repeat, no-repeat;
    background-position: 15% 0%, 90% 80%, center center;
    background-size: auto, auto, cover;
    background-attachment: scroll, scroll, fixed;
    color: var(--parchment);
    font-family:'Inter', sans-serif;
    padding: 48px 24px 80px;
  }

  .page{
    max-width: 920px;
    margin: 0 auto;
    background: var(--parchment);
    color: var(--ink);
    border-radius: 4px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.45);
    overflow: hidden;
  }

  .header{
    padding: 40px 48px 32px;
    border-bottom: 1px solid var(--line);
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin: 0 0 10px;
  }
  h1{
    font-family:'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 1.05;
    margin: 0 0 8px;
  }
  .subline{
    font-size: 14px;
    color: rgba(19,42,44,0.65);
    margin: 0;
  }
  .subline span{ font-family:'IBM Plex Mono', monospace; }

  .section{ padding: 32px 48px; border-bottom: 1px solid var(--line); }
  .section:last-child{ border-bottom: none; }
  .section-head{ display:flex; align-items:baseline; gap: 12px; margin-bottom: 20px; }
  .section-num{ font-family:'IBM Plex Mono', monospace; font-size: 12px; color: var(--copper); }
  .section-title{ font-family:'Cormorant Garamond', serif; font-weight: 600; font-size: 24px; margin: 0; }
  .section-desc{ font-size: 13px; color: rgba(19,42,44,0.6); margin: -12px 0 20px; }

  .consistency-banner{
    display:flex;
    align-items:center;
    gap: 14px;
    background: rgba(95,122,82,0.12);
    border: 1px solid rgba(95,122,82,0.35);
    border-radius: 3px;
    padding: 14px 18px;
    margin-bottom: 22px;
  }
  .consistency-icon{
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--moss); color: var(--parchment);
    display:flex; align-items:center; justify-content:center;
    font-weight: 700; font-size: 14px; flex-shrink:0;
  }
  .consistency-text{ font-size: 13px; }
  .consistency-text strong{ font-family:'IBM Plex Mono', monospace; }

  .check-list{ display:flex; flex-direction:column; }
  .check-item{
    display:grid;
    grid-template-columns: 22px 1fr auto;
    grid-auto-rows: auto;
    align-items:center;
    gap: 12px;
    padding: 10px 0;
    border-top: 1px dashed var(--line);
    font-size: 13px;
  }
  .check-item:first-child{ border-top:none; }
  .check-icon{
    width: 18px; height: 18px; border-radius: 50%;
    display:flex; align-items:center; justify-content:center;
    font-size: 11px; font-weight: 700;
  }
  .check-icon.ok{ background: var(--moss); color: var(--parchment); }
  .check-icon.bad{ background: var(--rust); color: var(--parchment); }
  .check-icon.note{ background: var(--gold); color: var(--ink); }
  .check-note{ font-family:'IBM Plex Mono', monospace; font-size: 11px; color: rgba(19,42,44,0.55); text-align:right; white-space:nowrap; }
  .check-detail{ grid-column: 2 / 4; font-size: 12px; color: rgba(19,42,44,0.6); line-height: 1.45; margin-top: 2px; }

  .coverage-note{
    margin-top: 14px;
    font-size: 12px;
    color: rgba(19,42,44,0.6);
    border-left: 3px solid var(--gold);
    padding-left: 12px;
  }

  .boss-table{ width:100%; border-collapse: collapse; font-size: 13px; }
  .boss-table th{
    text-align:left;
    font-family:'IBM Plex Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(19,42,44,0.5);
    padding: 8px 10px;
    border-bottom: 1px solid var(--line);
  }
  .th-help{ cursor: help; border-bottom-style: dotted; text-decoration: underline dotted; text-underline-offset: 3px; }
  .boss-table td{
    padding: 12px 10px;
    border-bottom: 1px dashed var(--line);
    vertical-align: middle;
  }
  .boss-table tr:last-child td{ border-bottom:none; }
  .boss-name{ font-weight: 600; }
  .boss-name a{ color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--copper); }
  .boss-name a:hover{ color: var(--copper); }
  .num-cell{ font-family:'IBM Plex Mono', monospace; text-align:right; }
  .pctl-cell{ font-family:'IBM Plex Mono', monospace; text-align:right; }
  .pctl-pill{
    display:inline-block;
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 11px;
    background: var(--parchment-dim);
  }
  .pctl-pill.has-data{ background: rgba(201,122,61,0.15); color: var(--ink); font-weight:600; }
  .pctl-pill.pending{ color: rgba(19,42,44,0.4); font-style: italic; font-weight:400; }
  .overheal-cell.high{ color: var(--rust); font-weight:600; }
  .link-arrow{ font-family:'IBM Plex Mono', monospace; font-size: 11px; color: var(--copper); }

  .footer{
    padding: 24px 48px 32px;
    font-family:'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(19,42,44,0.4);
    display:flex;
    justify-content: space-between;
  }
</style>
{% if theme_style_block %}{{ theme_style_block|safe }}{% endif %}
</head>
<body>

<div class="page">

  <div class="header">
    <p class="eyebrow"><a href="../index.html" style="color:var(--copper); text-decoration:none;">← All raids</a> &nbsp;·&nbsp; Raid Audit — {{ raid_title }} — {{ raid_date_display }}</p>
    <h1>{{ healer_name }}</h1>
    <p class="subline">{{ healer_class_spec }} &nbsp;·&nbsp; ilvl {{ item_level }} &nbsp;·&nbsp; report <span>{{ report_code }}</span> &nbsp;·&nbsp; {{ bosses_killed_label }}{% if theme_tag %} &nbsp;·&nbsp; <span style="color:var(--copper);">{{ theme_tag }}</span>{% endif %}</p>
    {% if spec_coverage_note %}
    <p class="section-desc" style="margin:8px 0 0;">{{ spec_coverage_note }}</p>
    {% endif %}
  </div>

  <div class="section">
    <div class="section-head">
      <span class="section-num">01</span>
      <h2 class="section-title">Gear audit</h2>
    </div>
    <p class="section-desc">One audit for the whole raid night — gear was checked against every one of the {{ n_kills }} kills below.</p>

    <div class="consistency-banner">
      <div class="consistency-icon">✓</div>
      <div class="consistency-text">Loadout is <strong>{{ gear_consistency_finding }}</strong> across all {{ n_kills }} boss kills.</div>
    </div>

    <div class="check-list">
      {% for item in gear_items %}
      <div class="check-item">
        <div class="check-icon {{ item.icon }}">{{ item.glyph }}</div>
        <div>{{ item.description }}</div>
        <div class="check-note">{{ item.detail }}</div>
        <div class="check-detail">{{ item.long_detail }}</div>
      </div>
      {% endfor %}
    </div>

    <div class="coverage-note">{{ gear_finding_note }}</div>
  </div>

  <div class="section">
    <div class="section-head">
      <span class="section-num">02</span>
      <h2 class="section-title">Per-boss summary</h2>
    </div>
    <p class="section-desc">HPS and overheal are real, computed from {{ healer_name }}'s own fight logs. Percentile is only shown where we've pulled the real WCL ranking for that exact pull — click a boss name for the full audit.</p>

    {% if ilvl_healing_rank_summary %}
    <p class="section-desc">{{ ilvl_healing_rank_summary }}</p>
    {% endif %}
    {% if raw_healing_rank_summary %}
    <p class="section-desc">{{ raw_healing_rank_summary }}</p>
    {% endif %}

    {% if raid_warning_banner %}
    <div class="consistency-banner" style="background: rgba(181,80,58,0.10); border-color: rgba(181,80,58,0.35);">
      <div class="consistency-icon" style="background: var(--rust);">!</div>
      <div class="consistency-text">{{ raid_warning_banner|safe }}</div>
    </div>
    {% endif %}

    <table class="boss-table">
      <thead>
        <tr>
          <th>Boss</th>
          <th style="text-align:right;">HPS</th>
          <th style="text-align:right;">Overheal</th>
          <th style="text-align:right;" class="th-help" title="Rank among the other healers in this same raid on this same fight, using WCL's own real HPS Performance Comparison (By Item Level) percentile per healer - not the Top 100 sample.">iLvl Healing Rank</th>
          <th style="text-align:right;" class="th-help" title="Rank among the same healers in this same raid on this same fight, using real raw total healing done instead of an item-level-adjusted percentile - a genuinely independent ranking from iLvl Healing Rank, not the same number relabeled.">Raw Healing Rank</th>
          <th style="text-align:right;">WCL Percentile</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for row in boss_summary_rows %}
        <tr>
          <td class="boss-name"><a href="healer_audit_{{ row.slug }}.html">{{ row.boss_name }}</a></td>
          <td class="num-cell">{{ row.hps }}</td>
          <td class="num-cell{{ row.overheal_high_class }}">{{ row.overheal_pct }}%</td>
          <td class="pctl-cell th-help" title="Rank among the other healers in this same raid on this same fight, using WCL's own real HPS Performance Comparison (By Item Level) percentile per healer - not the Top 100 sample.">{{ row.ilvl_healing_rank_label }}</td>
          <td class="pctl-cell th-help" title="Rank among the same healers in this same raid on this same fight, using real raw total healing done instead of an item-level-adjusted percentile - a genuinely independent ranking from iLvl Healing Rank, not the same number relabeled.">{{ row.raw_healing_rank_label }}</td>
          <td class="pctl-cell"><span class="pctl-pill has-data">{{ row.percentile }}th</span></td>
          <td class="link-arrow">→</td>
        </tr>
        {% endfor %}
    </tbody>
    </table>

    <div class="coverage-note">{{ raid_summary_finding }}</div>
  </div>

  <div class="footer">
    <span>All data real: {{ healer_name }}'s fight logs (report {{ report_code }}) + WCL rankings where pulled</span>
  </div>

</div>

</body>
</html>
